# =============================================================================
# TumaGo Backend — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# LOCAL DEV:  Only needs SECRET_KEY, POSTGRES_PASSWORD, GOOGLE_MAPS_API_KEY,
#             FIREBASE_CREDENTIALS, and PAYNOW keys.
# AWS PHASE 1: Also needs RDS_HOST, ELASTICACHE_HOST, ECR_REGISTRY, and
#              per-service DB passwords. See production.md for full details.
# =============================================================================

# ---------------------------------------------------------------------------
# Shared JWT secret — MUST be the same across Go services and Django
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-64-char-string

# ---------------------------------------------------------------------------
# PostgreSQL (local dev — used by docker-compose.yml)
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DEBUG=False
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://your-ec2-public-ip

# ---------------------------------------------------------------------------
# Google APIs
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ---------------------------------------------------------------------------
# Firebase — paste the full JSON content of your service account key
# Get it from: Firebase Console → Project Settings → Service Accounts
#              → Generate New Private Key
# Paste the entire JSON as a single line (no newlines)
# ---------------------------------------------------------------------------
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ---------------------------------------------------------------------------
# Firebase credentials file path (for notification service)
# Points to the JSON key file on the host machine
# ---------------------------------------------------------------------------
FIREBASE_CREDENTIALS_FILE=./firebase-credentials.json

# ---------------------------------------------------------------------------
# Paynow Payment Gateway
# Get from: https://www.paynow.co.zw → Integration Settings
# ---------------------------------------------------------------------------
PAYNOW_RETURN_URL=https://tumago.co.zw/payment-return
PAYNOW_RESULT_URL=https://your-server-domain.com/api/v1/payment/callback/
PAYNOW_INTEGRATION_ID=your-paynow-integration-id
PAYNOW_INTEGRATION_KEY=your-paynow-integration-key

# ---------------------------------------------------------------------------
# Matching
# ---------------------------------------------------------------------------
SEARCH_RADIUS_KM=15

# =============================================================================
# AWS PHASE 1 ONLY — uncomment and fill when deploying to EC2 with RDS
# See production.md for setup instructions
# =============================================================================

# ── RDS PostgreSQL (replaces local db container) ────────────────────────
# RDS_HOST=your-rds-endpoint.af-south-1.rds.amazonaws.com
# DJANGO_DB_PASS=your-django-schema-password
# LOCATION_DB_PASS=your-location-schema-password
# MATCHING_DB_PASS=your-matching-schema-password
# NOTIFICATION_DB_PASS=your-notification-schema-password

# ── ElastiCache Redis (replaces local redis container) ──────────────────
# ELASTICACHE_HOST=your-redis.xxxxx.af-south-1.cache.amazonaws.com

# ── ECR Container Registry ─────────────────────────────────────────────
# ECR_REGISTRY=123456789.dkr.ecr.af-south-1.amazonaws.com
