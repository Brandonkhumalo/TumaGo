# =============================================================================
# TumaGo Backend — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Shared secret — MUST be the same across Go services and Django
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-random-64-char-string

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD=change-me-to-a-strong-password

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DEBUG=False
ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://your-ec2-public-ip

# ---------------------------------------------------------------------------
# Google APIs
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ---------------------------------------------------------------------------
# Firebase — paste the full JSON content of your service account key
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Paste the entire JSON as a single line (no newlines)
# ---------------------------------------------------------------------------
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ---------------------------------------------------------------------------
# Firebase credentials file path (for notification service in production)
# Points to the JSON key file on the host machine
# ---------------------------------------------------------------------------
FIREBASE_CREDENTIALS_FILE=./firebase-credentials.json

# ---------------------------------------------------------------------------
# Matching
# ---------------------------------------------------------------------------
SEARCH_RADIUS_KM=15

# ---------------------------------------------------------------------------
# Optional — only needed for production compose
# ---------------------------------------------------------------------------
# REGISTRY=your-ecr-registry
# VERSION=latest
# REDIS_PASSWORD=
# GRAFANA_PASSWORD=admin
