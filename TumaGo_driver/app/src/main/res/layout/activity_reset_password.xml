<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    tools:context=".activities.ResetPassword">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/AppBarLayoutHome"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarHome"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Reset Password"
            app:titleTextColor="@color/blackish"
            app:navigationIcon="@drawable/back"/>

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/AppBarLayoutHome"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update Your Password"
                android:textSize="22sp"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/blackish"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter your current password and choose a new one"
                android:textSize="14sp"
                android:fontFamily="sans-serif"
                android:textColor="@color/secondary_text"
                android:layout_marginBottom="32dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Current Password"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/blackish"
                android:layout_marginBottom="6dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/background_input"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/oldPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@null"
                    android:hint="Current password"
                    android:padding="14dp"
                    android:inputType="textPassword"
                    android:textColorHint="@color/hint_text"
                    android:textColor="@color/blackish"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/toggleOldPassword"/>

                <ImageView
                    android:id="@+id/toggleOldPassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/pass"
                    android:contentDescription="Toggle Visibility"/>

            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="New Password"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/blackish"
                android:layout_marginBottom="6dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/background_input"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@null"
                    android:hint="New password"
                    android:padding="14dp"
                    android:inputType="textPassword"
                    android:textColorHint="@color/hint_text"
                    android:textColor="@color/blackish"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/togglePassword"/>

                <ImageView
                    android:id="@+id/togglePassword"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/pass"
                    android:contentDescription="Toggle Visibility"/>

            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Confirm New Password"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/blackish"
                android:layout_marginBottom="6dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/background_input"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/passwordConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@null"
                    android:hint="Confirm new password"
                    android:padding="14dp"
                    android:inputType="textPassword"
                    android:textColorHint="@color/hint_text"
                    android:textColor="@color/blackish"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@+id/togglePasswordConfirm"/>

                <ImageView
                    android:id="@+id/togglePasswordConfirm"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="14dp"
                    android:src="@drawable/pass"
                    android:contentDescription="Toggle Visibility"/>

            </RelativeLayout>

            <TextView
                android:id="@+id/passwordChanged"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Password changed successfully"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"
                android:textColor="@color/success"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/passwordUnchanged"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Failed to change password, please try again"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp"
                android:textColor="@color/error"
                android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/changePassword"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Update Password"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/primary"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
