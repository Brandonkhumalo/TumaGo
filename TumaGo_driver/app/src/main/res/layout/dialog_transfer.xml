<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/transferAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Amount (e.g. 5.00)"
        android:inputType="numberDecimal"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Transfer Direction"
        android:textSize="14sp"
        android:textColor="@color/blackish"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/transferDirectionGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/radioOwedToWallet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Owed Balance -> Wallet"
            android:checked="true"/>

        <RadioButton
            android:id="@+id/radioWalletToOwed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wallet -> Owed Balance"/>
    </RadioGroup>

</LinearLayout>
