<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Map fills the entire screen -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top floating menu button -->
    <androidx.cardview.widget.CardView
        android:id="@+id/menuButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/card_bg">

        <ImageView
            android:id="@+id/menuOption"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/menu"
            android:padding="12dp"
            android:scaleType="fitCenter"/>

    </androidx.cardview.widget.CardView>

    <!-- Side menu overlay (full-screen scrim + panel) -->
    <FrameLayout
        android:id="@+id/MenuList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone">

        <!-- Panel slides in from left -->
        <LinearLayout
            android:layout_width="300dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="@color/card_bg"
            android:fitsSystemWindows="true"
            android:layout_gravity="start">

            <!-- Branded gradient header -->
            <RelativeLayout
                android:id="@+id/goToProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/menu_drawer_header_bg"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="24dp">

                <!-- Close button top-right -->
                <ImageView
                    android:id="@+id/close"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginTop="-8dp"
                    android:src="@drawable/close"
                    android:tint="@color/white"
                    android:padding="6dp"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <!-- Avatar circle with initials -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/avatarCard"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    app:cardCornerRadius="32dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#33FFFFFF"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:id="@+id/avatarInitials"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="D"
                        android:textSize="22sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium"/>

                </androidx.cardview.widget.CardView>

                <!-- Name -->
                <TextView
                    android:id="@+id/mainUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/avatarCard"
                    android:text="Driver Name"
                    android:fontFamily="sans-serif-medium"
                    android:textSize="18sp"
                    android:textColor="@color/white"/>

                <!-- Rating + Driver badge row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/mainUsername"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/star"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:id="@+id/mainRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5.0"
                        android:textSize="13sp"
                        android:textColor="#B3FFFFFF"
                        android:fontFamily="sans-serif"/>

                    <!-- Driver badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Driver"
                        android:textSize="11sp"
                        android:textColor="@color/white"
                        android:fontFamily="sans-serif-medium"
                        android:background="#33FFFFFF"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="3dp"
                        android:paddingBottom="3dp"
                        android:layout_marginStart="10dp"/>

                </LinearLayout>

            </RelativeLayout>

            <!-- Menu items -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingTop="12dp">

                <!-- Deliveries Made -->
                <LinearLayout
                    android:id="@+id/deliveries"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/menu_item_ripple"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_menu_item_bg"
                        android:layout_marginEnd="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/parcel"
                            android:tint="@color/light_blue"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Deliveries Made"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/blackish"/>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/hint_text"/>

                </LinearLayout>

                <!-- Finances -->
                <LinearLayout
                    android:id="@+id/finances"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/menu_item_ripple"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_menu_item_bg"
                        android:layout_marginEnd="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/payments"
                            android:tint="@color/light_blue"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Finances"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/blackish"/>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/hint_text"/>

                </LinearLayout>

                <!-- Support -->
                <LinearLayout
                    android:id="@+id/support"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/menu_item_ripple"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_menu_item_bg"
                        android:layout_marginEnd="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/support"
                            android:tint="@color/light_blue"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Support"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/blackish"/>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/hint_text"/>

                </LinearLayout>

                <!-- Upload Docs -->
                <LinearLayout
                    android:id="@+id/upload"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/menu_item_ripple"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_menu_item_bg"
                        android:layout_marginEnd="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/upload1"
                            android:tint="@color/light_blue"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Upload Docs"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/blackish"/>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/hint_text"/>

                </LinearLayout>

                <!-- Settings -->
                <LinearLayout
                    android:id="@+id/goToSettings"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/menu_item_ripple"
                    android:clickable="true"
                    android:focusable="true">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/ic_menu_item_bg"
                        android:layout_marginEnd="16dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_settings"
                            android:tint="@color/light_blue"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Settings"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/blackish"/>

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_chevron_right"
                        android:tint="@color/hint_text"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Log Out button with red border -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp"
                android:paddingTop="8dp">

                <LinearLayout
                    android:id="@+id/logOut"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/logout_border"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/logout"
                        android:tint="@color/error"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Log Out"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/error"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
