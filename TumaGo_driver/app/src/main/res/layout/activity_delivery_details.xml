<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/page_bg"
    tools:context=".activities.DeliveryDetails">

    <!-- Map -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tripDetailsCard"/>

    <!-- Bottom card with delivery info -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tripDetailsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="20dp"
        app:cardElevation="12dp"
        app:strokeWidth="0dp"
        android:layout_margin="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header: requester name + fare -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="New Delivery Request"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif"
                        android:textColor="@color/secondary_text"/>

                    <TextView
                        android:id="@+id/RequesterName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Customer Name"
                        android:textSize="20sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/blackish"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/DeliveryFare"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$20.50"
                    android:textSize="24sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/primary"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="12dp"/>

            <!-- Drop-off and distance row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/location2"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:id="@+id/drop_off"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Delivery destination"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="@color/blackish"/>

                <TextView
                    android:id="@+id/distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="12 km"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/primary"/>

            </LinearLayout>

            <!-- Accept swipe card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/acceptCard"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                app:cardBackgroundColor="@color/page_bg"
                app:cardCornerRadius="14dp"
                app:strokeColor="@color/input_border"
                app:strokeWidth="1.5dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/acceptTrip"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@color/primary"
                    android:layout_gravity="start">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accept Delivery"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/white"
                        android:textSize="16sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
