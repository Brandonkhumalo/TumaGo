<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg"
    tools:context=".auth.Transport">

    <!-- Page 1: Choose vehicle type -->
    <ScrollView
        android:id="@+id/chooseVehicle"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/primary"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Choose Your Vehicle"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select how you want to earn with TumaGo"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif"
                    android:textColor="#CCffffff"/>

            </LinearLayout>

            <!-- Scooter card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/scooter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:orientation="horizontal"
                        android:background="@color/primary"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="DELIVERY"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-black"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/deliver"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Deliver with Motorbike"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="@color/blackish"
                                android:layout_marginBottom="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="License: Local  •  Age: 18+"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/secondary_text"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vehicle: Scooter / Motorbike"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/secondary_text"/>

                        </LinearLayout>

                        <ImageView
                            android:layout_width="90dp"
                            android:layout_height="60dp"
                            android:src="@drawable/scooter"
                            android:scaleType="fitCenter"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Van card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/van"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:orientation="horizontal"
                        android:background="@color/primary_dark"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="DELIVERY"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-black"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/deliver"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Deliver with Van"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="@color/blackish"
                                android:layout_marginBottom="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="License: Local / International  •  Age: 20+"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/secondary_text"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vehicle: Van"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/secondary_text"/>

                        </LinearLayout>

                        <ImageView
                            android:layout_width="90dp"
                            android:layout_height="60dp"
                            android:src="@drawable/van"
                            android:scaleType="fitCenter"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Truck card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/truck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:orientation="horizontal"
                        android:background="@color/blackish"
                        android:paddingHorizontal="16dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="DELIVERY"
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-black"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/deliver"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Deliver with Truck"
                                android:textSize="17sp"
                                android:fontFamily="sans-serif-black"
                                android:textColor="@color/blackish"
                                android:layout_marginBottom="6dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="License: Local / International  •  Age: 20+"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/secondary_text"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Vehicle: Truck"
                                android:textSize="13sp"
                                android:fontFamily="sans-serif"
                                android:textColor="@color/secondary_text"/>

                        </LinearLayout>

                        <ImageView
                            android:layout_width="90dp"
                            android:layout_height="60dp"
                            android:src="@drawable/truck"
                            android:scaleType="fitCenter"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/Continue"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Continue"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/primary"/>

        </LinearLayout>

    </ScrollView>

    <!-- Page 2: Vehicle registration -->
    <ScrollView
        android:id="@+id/vehicleRegistration"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@color/primary"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vehicle Registration"
                    android:textSize="22sp"
                    android:fontFamily="sans-serif-black"
                    android:textColor="@color/white"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Vehicle Make"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/blackish"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/vehicle"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/background_input2"
                android:padding="14dp"
                android:hint="e.g. Toyota"
                android:textColorHint="@color/hint_text"
                android:inputType="textPersonName"
                android:textColor="@color/blackish"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Model"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/blackish"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/model"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/background_input2"
                android:padding="14dp"
                android:hint="e.g. Corolla"
                android:textColorHint="@color/hint_text"
                android:inputType="textPersonName"
                android:textColor="@color/blackish"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Color"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/blackish"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/color"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/background_input2"
                android:padding="14dp"
                android:hint="e.g. White"
                android:textColorHint="@color/hint_text"
                android:inputType="textPersonName"
                android:textColor="@color/blackish"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Number Plate"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/blackish"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/numberPlate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/background_input2"
                android:padding="14dp"
                android:hint="e.g. AEZ 123 GP"
                android:textColorHint="@color/hint_text"
                android:inputType="textPersonName"
                android:textColor="@color/blackish"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/finishReg"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Complete Registration"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:fontFamily="sans-serif-medium"
                android:backgroundTint="@color/primary"/>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
