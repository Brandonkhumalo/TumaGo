<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/page_bg"
    android:gravity="center"
    tools:context=".Activities.NoDriverFound">

    <!-- Illustration card -->
    <androidx.cardview.widget.CardView
        android:layout_width="160dp"
        android:layout_height="160dp"
        app:cardCornerRadius="80dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginBottom="28dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/no_driver"
            android:padding="24dp"
            android:scaleType="fitCenter"/>

    </androidx.cardview.widget.CardView>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No Drivers Found"
        android:fontFamily="sans-serif-black"
        android:textSize="24sp"
        android:textColor="@color/dark_blue"
        android:layout_marginBottom="10dp"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="We couldn't find an available driver&#10;in your area right now."
        android:textSize="15sp"
        android:textColor="@color/secondary_text"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="12dp"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"/>

    <!-- Hint -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Please try again in a few minutes."
        android:textSize="13sp"
        android:textColor="@color/hint_text"
        android:gravity="center"
        android:layout_marginBottom="40dp"/>

    <!-- Go home button -->
    <Button
        android:id="@+id/goHome"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:text="Try Again"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/button"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"/>

</LinearLayout>
