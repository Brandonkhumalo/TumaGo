<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/deliveryRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_bg">

    <!-- Map Fragment fills entire screen -->
    <FrameLayout
        android:id="@+id/map_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Bottom panel: inputs + vehicle picker + button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_bg"
        android:layout_gravity="bottom"
        android:elevation="12dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@color/divider"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Book a Delivery"
            android:fontFamily="sans-serif-black"
            android:textSize="18sp"
            android:textColor="@color/dark_blue"
            android:layout_marginBottom="14dp"/>

        <!-- Origin input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/background_input"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle"/>

            <EditText
                android:id="@+id/input_origin"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Pickup location"
                android:background="@null"
                android:paddingStart="12dp"
                android:textColorHint="@color/hint_text"
                android:textColor="@color/blackish"
                android:textSize="14sp"
                android:inputType="textCapSentences"
                android:singleLine="true"/>

        </LinearLayout>

        <!-- Destination input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/background_input"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@color/error"/>

            <EditText
                android:id="@+id/input_dest"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Delivery destination"
                android:background="@null"
                android:paddingStart="12dp"
                android:textColorHint="@color/hint_text"
                android:textColor="@color/blackish"
                android:textSize="14sp"
                android:inputType="textCapSentences"
                android:singleLine="true"/>

        </LinearLayout>

        <!-- Distance text -->
        <TextView
            android:id="@+id/distance_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/secondary_text"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <!-- Vehicle selection (shown after route is set) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/scooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Vehicle type label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose Vehicle"
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp"/>

                <!-- Horizontal vehicle RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/mainRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Find driver button -->
                <Button
                    android:id="@+id/LookForDriver"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Find a Driver"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/button"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
