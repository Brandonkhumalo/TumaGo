<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/page_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/tuma_go_logo"
            android:scaleType="fitCenter"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:fontFamily="sans-serif-black"
            android:textSize="26sp"
            android:textColor="@color/dark_blue"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/pageNumberTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Step 1 of 2"
            android:textSize="13sp"
            android:textColor="@color/secondary_text"
            android:gravity="center"
            android:layout_marginBottom="24dp"/>

        <ProgressBar
            android:id="@+id/progressSign"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/light_blue"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Page 1: Personal Info -->
        <LinearLayout
            android:id="@+id/infoRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="First Name" android:textSize="13sp" android:textColor="@color/blackish" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/usernameInput" android:layout_width="match_parent" android:layout_height="52dp" android:hint="First name" android:background="@drawable/background_input" android:paddingHorizontal="16dp" android:textColorHint="@color/hint_text" android:inputType="textPersonName" android:textColor="@color/blackish" android:textSize="15sp" android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Surname" android:textSize="13sp" android:textColor="@color/blackish" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/surnameInput" android:layout_width="match_parent" android:layout_height="52dp" android:hint="Surname" android:background="@drawable/background_input" android:paddingHorizontal="16dp" android:textColorHint="@color/hint_text" android:inputType="textPersonName" android:textColor="@color/blackish" android:textSize="15sp" android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Phone Number" android:textSize="13sp" android:textColor="@color/blackish" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp" android:orientation="horizontal" android:background="@drawable/background_input" android:layout_marginBottom="14dp">
                <Spinner android:id="@+id/spinnerCountryCode" android:layout_width="wrap_content" android:layout_height="match_parent" android:paddingStart="4dp" android:paddingEnd="4dp"/>
                <View android:layout_width="1dp" android:layout_height="match_parent" android:background="@color/input_border"/>
                <EditText android:id="@+id/phoneNumberInput" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:hint="Phone number" android:background="@null" android:paddingHorizontal="12dp" android:textColorHint="@color/hint_text" android:inputType="phone" android:textColor="@color/blackish" android:textSize="15sp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Page 2: Account Details -->
        <LinearLayout
            android:id="@+id/dataForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Email Address" android:textSize="13sp" android:textColor="@color/blackish" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/emailInput" android:layout_width="match_parent" android:layout_height="52dp" android:hint="Email address" android:background="@drawable/background_input" android:paddingHorizontal="16dp" android:textColorHint="@color/hint_text" android:inputType="textEmailAddress" android:textColor="@color/blackish" android:textSize="15sp" android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Password" android:textSize="13sp" android:textColor="@color/blackish" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
            <RelativeLayout android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginBottom="14dp">
                <EditText android:id="@+id/passwordInput" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="Create password" android:background="@drawable/background_input" android:paddingStart="16dp" android:paddingEnd="50dp" android:textColorHint="@color/hint_text" android:inputType="textPassword" android:textColor="@color/blackish" android:textSize="15sp"/>
                <ImageView android:id="@+id/togglePassword" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:layout_marginEnd="14dp" android:src="@drawable/pass" android:tint="@color/hint_text"/>
            </RelativeLayout>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Confirm Password" android:textSize="13sp" android:textColor="@color/blackish" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
            <RelativeLayout android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginBottom="20dp">
                <EditText android:id="@+id/passwordConfirm" android:layout_width="match_parent" android:layout_height="match_parent" android:hint="Confirm password" android:background="@drawable/background_input" android:paddingStart="16dp" android:paddingEnd="50dp" android:textColorHint="@color/hint_text" android:inputType="textPassword" android:textColor="@color/blackish" android:textSize="15sp"/>
                <ImageView android:id="@+id/togglePasswordConfirm" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:layout_marginEnd="14dp" android:src="@drawable/pass" android:tint="@color/hint_text"/>
            </RelativeLayout>

        </LinearLayout>

        <!-- Address fields (kept as fields container) -->
        <LinearLayout
            android:id="@+id/fields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Street Address" android:textSize="13sp" android:textColor="@color/blackish" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/userStreet" android:layout_width="match_parent" android:layout_height="52dp" android:hint="Street address" android:background="@drawable/background_input" android:paddingHorizontal="16dp" android:textColorHint="@color/hint_text" android:textColor="@color/blackish" android:textSize="15sp" android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="City" android:textSize="13sp" android:textColor="@color/blackish" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/userCity" android:layout_width="match_parent" android:layout_height="52dp" android:hint="City" android:background="@drawable/background_input" android:paddingHorizontal="16dp" android:textColorHint="@color/hint_text" android:textColor="@color/blackish" android:textSize="15sp" android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Province" android:textSize="13sp" android:textColor="@color/blackish" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/userProvince" android:layout_width="match_parent" android:layout_height="52dp" android:hint="Province" android:background="@drawable/background_input" android:paddingHorizontal="16dp" android:textColorHint="@color/hint_text" android:textColor="@color/blackish" android:textSize="15sp" android:layout_marginBottom="14dp"/>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Postal Code" android:textSize="13sp" android:textColor="@color/blackish" android:fontFamily="sans-serif-medium" android:layout_marginBottom="6dp"/>
            <EditText android:id="@+id/userPostalCode" android:layout_width="match_parent" android:layout_height="52dp" android:hint="Postal code" android:background="@drawable/background_input" android:paddingHorizontal="16dp" android:textColorHint="@color/hint_text" android:inputType="number" android:textColor="@color/blackish" android:textSize="15sp" android:layout_marginBottom="20dp"/>

        </LinearLayout>

        <!-- Navigation buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/prevPage"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Back"
                android:textColor="@color/light_blue"
                android:textSize="15sp"
                android:visibility="gone"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/nextPage"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:text="Continue"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:background="@drawable/button"/>

        </LinearLayout>

        <Button
            android:id="@+id/regBtn"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Create Account"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:background="@drawable/button"
            android:visibility="gone"
            android:layout_marginTop="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Already have an account? " android:textColor="@color/secondary_text" android:textSize="14sp"/>
            <TextView android:id="@+id/signin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sign In" android:textColor="@color/light_blue" android:textSize="14sp" android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
