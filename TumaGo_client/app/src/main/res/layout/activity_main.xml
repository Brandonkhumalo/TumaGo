<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".Activities.MainActivity"
    android:background="@color/page_bg">

    <!-- Map Fragment fills entire screen -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top bar overlaid on map -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <androidx.cardview.widget.CardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/card_bg">
            <ImageView
                android:id="@+id/menuOption"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/menu"
                android:padding="10dp"
                android:tint="@color/dark_blue"
                android:scaleType="fitCenter"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Slide-out side menu overlay -->
    <LinearLayout
        android:id="@+id/MenuList"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/card_bg"
        android:visibility="gone"
        android:elevation="20dp"
        android:fitsSystemWindows="true">

        <!-- Branded header with gradient -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/menu_drawer_header_bg"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Close button top-right -->
            <ImageView
                android:id="@+id/close"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_marginTop="-8dp"
                android:src="@drawable/close"
                android:tint="@color/white"
                android:padding="6dp"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <!-- Avatar -->
            <androidx.cardview.widget.CardView
                android:id="@+id/avatarCard"
                android:layout_width="64dp"
                android:layout_height="64dp"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#33FFFFFF"
                android:layout_marginBottom="14dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/profile"
                    android:tint="@color/white"
                    android:padding="14dp"
                    android:scaleType="fitCenter"/>
            </androidx.cardview.widget.CardView>

            <!-- Name -->
            <TextView
                android:id="@+id/mainUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/avatarCard"
                android:text="User Name"
                android:fontFamily="sans-serif-medium"
                android:textSize="18sp"
                android:textColor="@color/white"/>

            <!-- Rating row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/mainUsername"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/star"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/mainRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5.0"
                    android:textSize="13sp"
                    android:textColor="#B3FFFFFF"
                    android:fontFamily="sans-serif"/>

            </LinearLayout>

        </RelativeLayout>

        <!-- Menu items -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingTop="12dp">

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/goToProfile"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/menu_item_ripple"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/ic_menu_item_bg"
                    android:layout_marginEnd="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/profile"
                        android:tint="@color/light_blue"/>
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Profile"
                    android:textSize="15sp"
                    android:textColor="@color/blackish"
                    android:fontFamily="sans-serif-medium"/>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/hint_text"/>

            </LinearLayout>

            <!-- Parcels -->
            <LinearLayout
                android:id="@+id/parcel"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/menu_item_ripple"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/ic_menu_item_bg"
                    android:layout_marginEnd="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/parcel"
                        android:tint="@color/light_blue"/>
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Parcels"
                    android:textSize="15sp"
                    android:textColor="@color/blackish"
                    android:fontFamily="sans-serif-medium"/>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/hint_text"/>

            </LinearLayout>

            <!-- Settings -->
            <LinearLayout
                android:id="@+id/goToSettings"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:background="@drawable/menu_item_ripple"
                android:clickable="true"
                android:focusable="true">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/ic_menu_item_bg"
                    android:layout_marginEnd="16dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_settings"
                        android:tint="@color/light_blue"/>
                </FrameLayout>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Settings"
                    android:textSize="15sp"
                    android:textColor="@color/blackish"
                    android:fontFamily="sans-serif-medium"/>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/hint_text"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Sign Out button with red border -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="20dp"
            android:paddingTop="8dp">

            <LinearLayout
                android:id="@+id/logOut"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/logout_border"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/logout"
                    android:tint="@color/error"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sign Out"
                    android:textSize="15sp"
                    android:textColor="@color/error"
                    android:fontFamily="sans-serif-medium"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom panel: inputs + vehicle picker + button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/card_bg"
        android:layout_gravity="bottom"
        android:elevation="12dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@color/divider"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Book a Delivery"
            android:fontFamily="sans-serif-black"
            android:textSize="18sp"
            android:textColor="@color/dark_blue"
            android:layout_marginBottom="14dp"/>

        <!-- Origin input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/background_input"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle"/>

            <EditText
                android:id="@+id/input_origin"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Pickup location"
                android:background="@null"
                android:paddingStart="12dp"
                android:textColorHint="@color/hint_text"
                android:textColor="@color/blackish"
                android:textSize="14sp"
                android:inputType="textCapSentences"
                android:singleLine="true"/>

        </LinearLayout>

        <!-- Destination input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/background_input"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@color/error"/>

            <EditText
                android:id="@+id/input_dest"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Delivery destination"
                android:background="@null"
                android:paddingStart="12dp"
                android:textColorHint="@color/hint_text"
                android:textColor="@color/blackish"
                android:textSize="14sp"
                android:inputType="textCapSentences"
                android:singleLine="true"/>

        </LinearLayout>

        <!-- Distance text -->
        <TextView
            android:id="@+id/distance_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/secondary_text"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="10dp"
            android:visibility="gone"/>

        <!-- Vehicle selection (shown after route is set) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/scooter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Vehicle type label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Choose Vehicle"
                    android:textSize="14sp"
                    android:textColor="@color/secondary_text"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="10dp"/>

                <!-- Horizontal vehicle RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/mainRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="16dp"/>

                <!-- Find driver button -->
                <Button
                    android:id="@+id/LookForDriver"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Find a Driver"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/button"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
