<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Activities.MainActivity"
    android:background="@color/page_bg">

    <!-- Map Fragment fills entire screen -->
    <fragment
        android:id="@+id/map"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top bar overlaid on map -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="44dp"
        android:paddingBottom="12dp">

        <androidx.cardview.widget.CardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white">
            <ImageView
                android:id="@+id/menuOption"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/menu"
                android:padding="10dp"
                android:tint="@color/dark_blue"
                android:scaleType="fitCenter"/>
        </androidx.cardview.widget.CardView>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <androidx.cardview.widget.CardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/tuma_go_logo"
                android:padding="6dp"
                android:scaleType="fitCenter"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Slide-out side menu overlay -->
    <LinearLayout
        android:id="@+id/MenuList"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/white"
        android:visibility="gone"
        android:elevation="20dp"
        android:paddingTop="52dp">

        <!-- Close button -->
        <ImageView
            android:id="@+id/close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/close"
            android:tint="@color/blackish"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="20dp"
            android:padding="4dp"/>

        <!-- User info section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/page_bg"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="16dp"
            android:layout_marginBottom="8dp">

            <androidx.cardview.widget.CardView
                android:layout_width="56dp"
                android:layout_height="56dp"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/light_blue"
                android:layout_marginBottom="10dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/profile"
                    android:tint="@color/white"
                    android:padding="12dp"
                    android:scaleType="fitCenter"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/mainUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User Name"
                android:fontFamily="sans-serif-black"
                android:textSize="16sp"
                android:textColor="@color/dark_blue"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/star"
                    android:layout_marginEnd="4dp"/>

                <TextView
                    android:id="@+id/mainRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5.0"
                    android:textSize="13sp"
                    android:textColor="@color/secondary_text"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Profile menu item -->
        <LinearLayout
            android:id="@+id/goToProfile"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/profile"
                android:tint="@color/dark_blue"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Profile"
                android:textSize="15sp"
                android:textColor="@color/blackish"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"/>

        <!-- Logout button -->
        <LinearLayout
            android:id="@+id/logOut"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/logout"
                android:tint="@color/error"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign Out"
                android:textSize="15sp"
                android:textColor="@color/error"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Bottom panel: inputs + vehicle picker + button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:layout_gravity="bottom"
        android:elevation="12dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <!-- Drag handle -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@color/divider"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Book a Delivery"
            android:fontFamily="sans-serif-black"
            android:textSize="18sp"
            android:textColor="@color/dark_blue"
            android:layout_marginBottom="14dp"/>

        <!-- Origin input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/background_input"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="10dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/circle"/>

            <EditText
                android:id="@+id/input_origin"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Pickup location"
                android:background="@null"
                android:paddingStart="12dp"
                android:textColorHint="@color/hint_text"
                android:textColor="@color/blackish"
                android:textSize="14sp"
                android:inputType="textCapSentences"
                android:singleLine="true"/>

        </LinearLayout>

        <!-- Destination input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/background_input"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="16dp">

            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@color/error"/>

            <EditText
                android:id="@+id/input_dest"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Delivery destination"
                android:background="@null"
                android:paddingStart="12dp"
                android:textColorHint="@color/hint_text"
                android:textColor="@color/blackish"
                android:textSize="14sp"
                android:inputType="textCapSentences"
                android:singleLine="true"/>

        </LinearLayout>

        <!-- Vehicle type label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose Vehicle"
            android:textSize="14sp"
            android:textColor="@color/secondary_text"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="10dp"/>

        <!-- Horizontal vehicle RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/mainRecycler"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginBottom="16dp"/>

        <!-- Find driver button -->
        <Button
            android:id="@+id/LookForDriver"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Find a Driver"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/button"/>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
